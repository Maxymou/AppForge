generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "debian-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model RoadmapNode {
  id        String        @id @default(cuid())
  title     String
  parentId  String?
  parent    RoadmapNode?  @relation("NodeChildren", fields: [parentId], references: [id], onDelete: Cascade)
  children  RoadmapNode[] @relation("NodeChildren")
  order     Int           @default(0)
  expanded  Boolean       @default(true)
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt
}

model Project {
  id          String           @id @default(cuid())
  name        String
  description String?
  readOnly    Boolean          @default(false)
  nodes       ProjectNode[]
  edges       ProjectEdge[]
  versions    ProjectVersion[]
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
}

model ProjectNode {
  id          String   @id @default(cuid())
  projectId   String
  project     Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  nodeId      String
  title       String
  description String?
  notes       String?
  items       String[] @default([])
  posX        Float    @default(0)
  posY        Float    @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model ProjectEdge {
  id        String   @id @default(cuid())
  projectId String
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  edgeId    String
  source    String
  target    String
  createdAt DateTime @default(now())
}

model ProjectVersion {
  id        String   @id @default(cuid())
  projectId String
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  snapshot  Json
  createdAt DateTime @default(now())
}
