# Backend
DATABASE_URL=postgresql://appforge:appforge_secret@postgres:5432/appforge
JWT_SECRET=super_secret_jwt_key_change_in_prod

# Default admin bootstrap account.
# Created only if this email does not already exist in DB.
# Updating ADMIN_PASSWORD later will not reset an existing user's password.
ADMIN_EMAIL=admin@appforge.local
ADMIN_PASSWORD=admin123

PORT=4000
